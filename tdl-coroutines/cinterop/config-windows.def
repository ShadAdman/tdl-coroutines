headers = td/telegram/td_json_client.h
package = org.drinkless.tdlib

compilerOpts = -DTDJSON_STATIC_DEFINE
linkerOpts = -Wl,/alternatename:_ZSt28__throw_bad_array_new_lengthv=__cxa_throw_bad_array_new_length -lcrypt32 -lpsapi -lssp
staticLibraries = libcrypto.a libssl.a libtdactor.a libtdapi.a libtdclient.a libtdcore.a libtddb.a libtde2e.a libtdjson_private.a libtdjson_static.a libtdmtproto.a libtdnet.a libtdsqlite.a libtdutils.a libz.a
