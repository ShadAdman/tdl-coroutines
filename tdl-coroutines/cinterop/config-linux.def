headers = td/telegram/td_json_client.h
package = org.drinkless.tdlib

#compilerOpts = -D_FILE_OFFSET_BITS=64
#linkerOpts = --defsym=__libc_single_threaded=0

staticLibraries = libtdjson_static.a libtdjson_private.a libtdclient.a libtdcore.a libtdapi.a libtdactor.a libtddb.a libtde2e.a libtdmtproto.a libtdnet.a libtdsqlite.a libtdutils.a libssl.a libcrypto.a libz.a

linkerOpts.linux_x64 = -ltdjson_static -ltdjson_private -ltdclient -ltdcore -ltdapi -ltdactor -ltddb -ltde2e -ltdmtproto -ltdnet -ltdsqlite -ltdutils -lssl -lcrypto -lz -lstdc++ -lpthread -lm -ldl