headers = td/telegram/td_json_client.h
package = org.drinkless.tdlib
linkerOpts = -lstdc++ -lgcc -lz -lpthread -ldl

staticLibraries = libtdjson_static.a libtdjson_private.a libtdclient.a libtdcore.a libtdapi.a libtdactor.a libtdnet.a libtdmtproto.a libtde2e.a libtddb.a libtdsqlite.a libtdutils.a libssl.a libcrypto.a