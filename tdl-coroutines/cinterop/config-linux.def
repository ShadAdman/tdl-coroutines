headers = td/telegram/td_json_client.h
package = org.drinkless.tdlib
linkerOpts = --defsym=__libc_single_threaded=0 -u __throw_bad_array_new_length -u _Sp_make_shared_tag

staticLibraries = libssl.a libcrypto.a libz.a libtdactor.a libtdapi.a libtdclient.a libtdcore.a libtddb.a libtde2e.a libtdjson_private.a libtdjson_static.a libtdmtproto.a libtdnet.a libtdsqlite.a libtdutils.a
