diff --git a/td/example/ios/build-openssl.sh b/td/example/ios/build-openssl.sh
--- a/td/example/ios/build-openssl.sh
+++ b/td/example/ios/build-openssl.sh
@@ -8,14 +8,14 @@ git reset --hard || exit 1
